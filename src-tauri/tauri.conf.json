{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "VACDevice",
  "version": "0.2.3",
  "identifier": "com.vacdevice.desktop",
  "build": {
    "beforeBuildCommand": "node scripts/bundle-sidecar.js",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3200",
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "splash.html",
      "icons/icon.png",
      "server/server.js",
      "server/package.json",
      "server/.next/**/*",
      "server/node_modules/**/*",
      "server/public/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDQThEMjRBNkE0ODVCNTUKUldSVlcwaHFTdEtvWFBSLzJEaG45TnBHQmREZGhhZS8zbFo4dnRlaW1WTjlOUVM0OSs2RmxKbTMK",
      "endpoints": [
        "https://o09u11p5v.qnssl.com/ssts/latest.json",
        "https://github.com/ggtiger/SSTS/releases/latest/download/latest.json"
      ]
    }
  }
}
